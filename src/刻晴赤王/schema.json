{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "default": {},
      "type": "object",
      "properties": {
        "当前时间": {
          "default": "璃月历·某日 深夜",
          "type": "string"
        },
        "当前地点": {
          "default": "璃月港·刻晴的私人宅邸·卧房内",
          "type": "string"
        },
        "在场人物": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "description": "人物名"
          },
          "additionalProperties": {
            "type": "string",
            "description": "人物状态描述"
          }
        }
      }
    },
    "核心意识": {
      "type": "object",
      "properties": {
        "堕落度": {
          "default": 5,
          "type": "number"
        },
        "意识清醒度": {
          "default": 100,
          "type": "number"
        },
        "抵抗意识": {
          "default": 80,
          "type": "number"
        },
        "内心独白": {
          "default": "",
          "type": "string"
        }
      }
    },
    "身体状态": {
      "default": {},
      "type": "object",
      "properties": {
        "开发度": {
          "default": 0,
          "type": "number"
        },
        "异常状态": {
          "default": "",
          "type": "string"
        },
        "当前行为": {
          "default": "",
          "type": "string"
        },
        "观感": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "enum": [
              "整体",
              "乳房",
              "臀部",
              "股间",
              "面部"
            ]
          },
          "additionalProperties": {
            "description": "当前部位状态描述",
            "default": "",
            "$ref": "#/$defs/__schema0"
          },
          "required": [
            "整体",
            "乳房",
            "臀部",
            "股间",
            "面部"
          ]
        }
      }
    },
    "服饰": {
      "default": {},
      "type": "object",
      "properties": {
        "整体": {
          "default": "",
          "type": "string"
        },
        "内衣": {
          "default": "",
          "type": "string"
        },
        "配件": {
          "default": {},
          "type": "object",
          "properties": {
            "手部": {
              "default": "",
              "type": "string"
            },
            "腿部与鞋履": {
              "default": "",
              "type": "string"
            },
            "饰品": {
              "default": "",
              "type": "string"
            },
            "神之眼": {
              "default": "",
              "type": "string"
            },
            "身体改造物": {
              "default": "",
              "type": "string"
            }
          }
        }
      }
    }
  },
  "required": [
    "核心意识"
  ],
  "$defs": {
    "__schema0": {
      "type": "string"
    }
  }
}